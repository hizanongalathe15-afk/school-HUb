PORT=5000
CLIENT_URL=http://localhost:5173

# Required database connection. Use Supabase/Render/AWS PostgreSQL in production.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5433/school_hub?schema=public"
AUTO_START_DATABASE=true

# Required auth secrets. Use long random strings in production.
JWT_SECRET="replace-with-long-access-token-secret"
JWT_REFRESH_SECRET="replace-with-long-refresh-token-secret"

# Optional Redis cache/session backend.
REDIS_ENABLED=false
REDIS_URL="redis://localhost:6379"

# Uploads and media.
UPLOAD_MAX_FILE_SIZE_MB=10
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="school-hub"

MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=""
MPESA_CONSUMER_SECRET=""
MPESA_SHORTCODE=""
MPESA_PASSKEY=""
MPESA_CALLBACK_URL="http://localhost:5000/api/fees/mpesa/callback"

SMS_PROVIDER=mock
SMS_API_KEY=""
SMS_USERNAME=""
SMS_SENDER_ID="SchoolHub"

# WhatsApp Business API. Disabled by default; simulation endpoint still works.
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_VERIFY_TOKEN="school-hub-verify"

# Email delivery.
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="School Hub <noreply@schoolhub.local>"
