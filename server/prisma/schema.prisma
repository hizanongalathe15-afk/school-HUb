generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  DEVELOPER
  PRINCIPAL
  ADMIN
  BURSAR
  STORE_KEEPER
  TEACHER
  PARENT
  STUDENT
  ALUMNI
  GUEST
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  HOLIDAY
}

enum ExamType {
  CAT1
  CAT2
  CAT3
  END_TERM
  MOCK
  KCSE
}

enum PaymentMethod {
  MPESA
  CASH
  CHEQUE
  BANK_TRANSFER
  CARD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIAL
}

enum TransactionType {
  FEE_PAYMENT
  EXPENSE
  SALARY
  REFUND
  BURSARY
  SCHOLARSHIP
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  FAILED
}

enum NotificationType {
  FEE_REMINDER
  RESULT_PUBLISHED
  ATTENDANCE_ALERT
  EVENT_REMINDER
  GENERAL_ANNOUNCEMENT
  EMERGENCY
  PAYMENT_CONFIRMATION
  MEETING_REQUEST
  LEAVE_REQUEST
  STREAK_ALERT
  MESSAGE_RECEIVED
  LIVE_CLASS
}

enum MeetingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum StockRequestStatus {
  PENDING
  APPROVED
  REJECTED
  ISSUED
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  PARTIAL_DELIVERY
  COMPLETED
  CANCELLED
  RETURNED
}

enum StockMovementType {
  RECEIVE
  ISSUE
  RETURN
  TRANSFER
  ADJUSTMENT
  WRITE_OFF
}

enum StockTakeStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum LibraryStatus {
  AVAILABLE
  BORROWED
  LOST
  DAMAGED
  UNDER_MAINTENANCE
}

enum MealType {
  BREAKFAST
  LUNCH
  SUPPER
  SNACK
}

enum BusStatus {
  ON_ROUTE
  ARRIVED
  DELAYED
  MAINTENANCE
  PARKED
}

enum StreakType {
  CLEANLINESS
  ACADEMIC
  ATTENDANCE
  BEHAVIOR
  PUNCTUALITY
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ComplaintPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Complaint {
  id          String          @id @default(cuid())
  parentId    String
  studentId   String?
  category    String
  subject     String
  description String
  priority    ComplaintPriority @default(NORMAL)
  status      ComplaintStatus @default(OPEN)
  attachments String[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  parent  Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id])
}

enum Language {
  EN
  SW
  FR
  AR
}

enum CommunicationType {
  SMS
  EMAIL
  WHATSAPP
  PUSH
  BULK_SMS
  BULK_EMAIL
  BULK_WHATSAPP
}

enum CommunicationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  PARTIAL
}

enum CertificateType {
  ACHIEVEMENT
  PARTICIPATION
  MERIT
  PERFECT_ATTENDANCE
  HONOR_ROLL
  GRADUATION
  APPRECIATION
}

enum MeetingType {
  PARENT_TEACHER
  STAFF
  BOARD
  EMERGENCY
  VIRTUAL
}

enum HomeworkStatus {
  PENDING
  SUBMITTED
  GRADED
  LATE
  MISSING
}

enum TeacherWorkflowStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PUBLISHED
  COMPLETED
  CANCELLED
}

enum TeacherRequestType {
  CLASS_SWAP
  SUBSTITUTION
  CLASSROOM_MAINTENANCE
  LAB_BOOKING
  LIBRARY_BOOKING
  SPORTS_FIELD_BOOKING
  TEACHING_AID
  EQUIPMENT_BORROW
  PRINTING
  TRAINING
  FEATURE
  SUPPORT
}

enum CocurricularType {
  SPORTS
  CLUBS
  DEBATE
  MUSIC
  DRAMA
  SCOUTS
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  role              Role      @default(PARENT)
  avatar            String?
  profileViews      Int       @default(0)
  isActive          Boolean   @default(true)
  isVerified        Boolean   @default(false)
  lastLogin         DateTime?
  lastLoginIP       String?
  resetToken        String?
  resetTokenExpires DateTime?
  twoFactorSecret   String?
  twoFactorEnabled  Boolean   @default(false)
  preferredLanguage Language  @default(EN)
  darkMode          Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  parent           Parent?
  teacher          Teacher?
  staff            Staff?
  student          Student?
  alumni           Alumni?
  sessions         Session[]
  deviceSessions   DeviceSession[]
  bursarWorkspaceRecords BursarWorkspaceRecord[]
  notifications    Notification[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  auditLogs        AuditLog[]
  deviceTokens     DeviceToken[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  platform  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model School {
  id              String   @id @default(cuid())
  name            String
  motto           String?
  mission         String?
  vision          String?
  founded         Int?
  founder         String?
  phone           String
  email           String
  website         String?
  address         String
  lat             Float?
  lng             Float?
  region          String?
  county          String?
  subCounty       String?
  ward            String?
  logo            String?
  coverImage      String?
  favicon         String?
  primaryColor    String   @default("#00ff41")
  secondaryColor  String   @default("#0a0a0a")
  primaryFont     String   @default("Inter")
  secondaryFont   String   @default("Poppins")
  whatsappGroupId String?
  whatsappApiKey  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  academicTerms          AcademicTerm[]
  events                 Event[]
  announcements          Announcement[]
  classes                Class[]
  subjects               Subject[]
  locationInfo           LocationInfo?
  infrastructure         Infrastructure?
  whatsappGroups         WhatsAppGroup[]
  paymentGateways        PaymentGateway[]
  admissionFormTemplates AdmissionFormTemplate[]
}

model AcademicTerm {
  id        String   @id @default(cuid())
  schoolId  String
  term      Int
  year      Int
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  holidays  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model LocationInfo {
  id                String   @id @default(cuid())
  schoolId          String   @unique
  soilType          String?
  soilQuality       String?
  roadAccess        String?
  roadDistance      String?
  roadImages        String[]
  surroundings      String?
  surroundingImages String[]
  climate           String?
  nearestTown       String?
  nearestHospital   String?
  nearestPolice     String?
  landmarks         String[]
  droneImages       String[]
  droneVideos       String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Infrastructure {
  id                   String   @id @default(cuid())
  schoolId             String   @unique
  classroomCount       Int
  classroomImages      String[]
  labCount             Int
  labImages            String[]
  computerLabCount     Int
  computerLabImages    String[]
  libraryCount         Int
  libraryImages        String[]
  libraryBooks         Int
  sportsFieldCount     Int
  sportsFieldImages    String[]
  dormitoryCount       Int
  dormitoryCapacity    Int
  dormitoryImages      String[]
  diningHallCapacity   Int
  diningHallImages     String[]
  chapelCount          Int
  chapelImages         String[]
  adminBlockCount      Int
  adminBlockImages     String[]
  staffRoomCount       Int
  staffRoomImages      String[]
  assemblyHallCapacity Int
  assemblyHallImages   String[]
  parkingSpaces        Int
  parkingImages        String[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Class {
  id             String   @id @default(cuid())
  schoolId       String
  name           String
  stream         String?
  capacity       Int      @default(50)
  classTeacherId String?
  whatsappGroupId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  school       School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students     Student[]
  subjects     SubjectClass[]
  attendance   Attendance[]
  timetable    Timetable[]
  classTeacher Teacher?       @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  homework     Homework[]
  teacherLessonPlans TeacherLessonPlan[]
  teacherRequests    TeacherRequest[]
  teacherExamIncidents TeacherExamIncident[]
  feeComponents FeeComponent[]
}

model Subject {
  id        String   @id @default(cuid())
  schoolId  String
  name      String
  code      String
  category  String
  isCore    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school       School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes      SubjectClass[]
  teachers     TeacherSubject[]
  results      Result[]
  teacherRanks TeacherRank[]
  timetable    Timetable[]
  homework     Homework[]
  teacherLessonPlans TeacherLessonPlan[]
  teacherRequests    TeacherRequest[]
  teacherExamIncidents TeacherExamIncident[]
}

model SubjectClass {
  id        String   @id @default(cuid())
  subjectId String
  classId   String
  teacherId String?
  createdAt DateTime @default(now())

  subject Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class   Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher Teacher? @relation(fields: [teacherId], references: [id])
}

model Student {
  id                String    @id @default(cuid())
  admissionNumber   String    @unique
  userId            String?   @unique
  firstName         String
  lastName          String
  middleName        String?
  dateOfBirth       DateTime
  gender            Gender
  classId           String?
  stream            String?
  parentId          String?
  photo             String?
  address           String?
  phone             String?
  email             String?
  bloodGroup        String?
  allergies         String[]
  medicalConditions Json?
  disability        String?
  enrollmentDate    DateTime  @default(now())
  graduationDate    DateTime?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime @updatedAt

  user                User?                 @relation(fields: [userId], references: [id])
  class               Class?                @relation(fields: [classId], references: [id])
  parent              Parent?               @relation(fields: [parentId], references: [id])
  fees                Fee[]
  payments            Payment[]
  attendance          Attendance[]
  results             Result[]
  discipline          Discipline[]
  messages            Message[]
  achievements        Achievement[]
  libraryCards        LibraryCard[]
  busAssignments      BusAssignment[]
  mealBookings        MealBooking[]
  healthRecords       HealthRecord[]
  notes               StudentNote[]
  streaks             StudentStreak[]
  certificates        Certificate[]
  cocurriculars       StudentCocurricular[]
  homeworkSubmissions HomeworkSubmission[]
  teacherExamIncidents TeacherExamIncident[]
  alumni              Alumni?
  meetings            Meeting[]
  complaints          Complaint[]
  feeAssignments      StudentFeeAssignment[]
  arrearsRecords      ArrearsRecord[]
  bursarApplications   BursarApplication[]
}

model Parent {
  id               String   @id @default(cuid())
  userId           String   @unique
  firstName        String
  lastName         String
  email            String   @unique
  phone            String
  alternativePhone String?
  relationship     String
  occupation       String?
  address          String?
  idNumber         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  students    Student[]
  payments    Payment[]
  messages    Message[]
  meetings    Meeting[]
  preferences ParentPreference?
  complaints  Complaint[]
}

model ParentPreference {
  id                 String   @id @default(cuid())
  parentId           String   @unique
  language           Language @default(EN)
  receiveEmail       Boolean  @default(true)
  receiveSMS         Boolean  @default(true)
  receiveWhatsApp    Boolean  @default(true)
  receivePush        Boolean  @default(true)
  feeReminderDays    Int      @default(7)
  darkMode           Boolean  @default(false)
  emailNotifications String[]
  smsNotifications   String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)
}

model Teacher {
  id             String   @id @default(cuid())
  userId         String   @unique
  firstName      String
  lastName       String
  email          String   @unique
  phone          String
  tscNumber      String?  @unique
  subject        String
  specialization String?
  qualification  String?
  experience     Int?
  dateHired      DateTime
  salary         Float?
  photo          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  classTeacher   Class[]          @relation("ClassTeacher")
  subjects       TeacherSubject[]
  results        Result[]
  leaves         LeaveRequest[]
  messages       Message[]
  notes          StudentNote[]
  meetings       Meeting[]
  ranks          TeacherRank[]
  subjectClasses SubjectClass[]
  attendance     Attendance[]
  timetable      Timetable[]
  homework       Homework[]
  lessonPlans    TeacherLessonPlan[]
  workflowItems  TeacherWorkspaceRecord[]
  requests       TeacherRequest[]
  reportArchives TeacherReportArchive[]
  examIncidents  TeacherExamIncident[]
  professionalRecords TeacherProfessionalRecord[]
  notificationPreference TeacherNotificationPreference?
}

model TeacherRank {
  id               String   @id @default(cuid())
  teacherId        String
  subjectId        String
  term             Int
  year             Int
  rank             Int
  averageScore     Float
  performanceScore Float
  studentCount     Int
  passedCount      Int
  createdAt        DateTime @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model TeacherSubject {
  id        String   @id @default(cuid())
  teacherId String
  subjectId String
  createdAt DateTime @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

model Staff {
  id         String   @id @default(cuid())
  userId     String   @unique
  firstName  String
  lastName   String
  email      String   @unique
  phone      String
  staffRole  String
  department String?
  idNumber   String?  @unique
  dateHired  DateTime
  salary     Float?
  photo      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Alumni {
  id              String   @id @default(cuid())
  userId          String   @unique
  studentId       String   @unique
  graduationYear  Int
  currentEmployer String?
  occupation      String?
  phone           String?
  email           String?
  address         String?
  isContributing  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  student       Student              @relation(fields: [studentId], references: [id])
  contributions AlumniContribution[]
}

model AlumniContribution {
  id        String   @id @default(cuid())
  alumniId  String
  amount    Float
  purpose   String
  date      DateTime @default(now())
  reference String?

  alumni Alumni @relation(fields: [alumniId], references: [id], onDelete: Cascade)
}

model Fee {
  id        String        @id @default(cuid())
  studentId String
  amount    Float
  type      String
  term      Int
  year      Int
  status    PaymentStatus @default(PENDING)
  dueDate   DateTime
  paidDate  DateTime?
  reference String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments Payment[]
}

model Payment {
  id            String        @id @default(cuid())
  feeId         String?
  studentId     String
  parentId      String?
  amount        Float
  method        PaymentMethod
  transactionId String?       @unique
  mpesaReceipt  String?       @unique
  status        PaymentStatus @default(COMPLETED)
  paymentDate   DateTime      @default(now())
  recordedBy    String
  notes         String?
  receiptNumber String?       @unique
  createdAt     DateTime      @default(now())

  fee     Fee?    @relation(fields: [feeId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
  parent  Parent? @relation(fields: [parentId], references: [id])
}

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  category    String
  description String
  date        DateTime @default(now())
  receipt     String?
  approvedBy  String
  recordedBy  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  date      DateTime         @default(now())
  status    AttendanceStatus
  checkIn   DateTime?
  checkOut  DateTime?
  notes     String?
  classId   String
  teacherId String?
  createdAt DateTime         @default(now())

  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher Teacher? @relation(fields: [teacherId], references: [id])
}

model StudentStreak {
  id            String     @id @default(cuid())
  studentId     String
  type          StreakType
  currentStreak Int        @default(0)
  longestStreak Int        @default(0)
  lastUpdated   DateTime   @default(now())
  lastBreakDate DateTime?
  breakReason   String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Result {
  id        String   @id @default(cuid())
  studentId String
  subjectId String
  examType  ExamType
  score     Float
  grade     String?
  points    Int?
  remarks   String?
  term      Int
  year      Int
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher   Teacher? @relation(fields: [teacherId], references: [id])
  teacherId String?
}

model Discipline {
  id          String    @id @default(cuid())
  studentId   String
  type        String
  category    String
  points      Int       @default(0)
  description String
  date        DateTime  @default(now())
  recordedBy  String
  action      String?
  resolvedAt  DateTime?
  resolvedBy  String?
  notes       String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String   @id @default(cuid())
  studentId   String
  title       String
  description String
  category    String
  date        DateTime @default(now())
  certificate String?
  awardedBy   String

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Certificate {
  id               String          @id @default(cuid())
  studentId        String
  type             CertificateType
  title            String
  description      String
  issueDate        DateTime        @default(now())
  pdfUrl           String
  templateId       String?
  issuedBy         String
  verified         Boolean         @default(true)
  verificationCode String          @unique

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Event {
  id          String   @id @default(cuid())
  schoolId    String
  title       String
  description String
  startDate   DateTime
  endDate     DateTime
  location    String
  type        String
  image       String?
  images      String[] @default([])
  videos      String[] @default([])
  media       Json?    // Array of {id, url, type, name, size} for flexible media
  isPublic    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Announcement {
  id              String    @id @default(cuid())
  schoolId        String
  title           String
  content         String
  audience        String
  isUrgent        Boolean   @default(false)
  sendWhatsApp    Boolean   @default(false)
  sendSMS         Boolean   @default(false)
  sendEmail       Boolean   @default(false)
  sendPush        Boolean   @default(false)
  whatsappGroupId String?
  publishedAt     DateTime  @default(now())
  expiresAt       DateTime?
  createdBy       String
  createdAt       DateTime  @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model WhatsAppGroup {
  id          String   @id @default(cuid())
  schoolId    String
  groupName   String
  groupId     String   @unique
  accessToken String?
  webhookUrl  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model BulkCommunication {
  id         String              @id @default(cuid())
  type       CommunicationType
  audience   String
  subject    String?
  content    String
  recipients Int
  delivered  Int                 @default(0)
  failed     Int                 @default(0)
  sentBy     String
  sentAt     DateTime            @default(now())
  status     CommunicationStatus @default(PENDING)

  logs CommunicationLog[]
}

model CommunicationLog {
  id            String              @id @default(cuid())
  bulkCommId    String?
  recipientId   String
  recipientType String
  type          CommunicationType
  status        CommunicationStatus
  error         String?
  sentAt        DateTime            @default(now())

  bulkComm BulkCommunication? @relation(fields: [bulkCommId], references: [id])
}

model Message {
  id         String        @id @default(cuid())
  senderId   String
  receiverId String
  parentId   String?
  teacherId  String?
  studentId  String?
  replyToId  String?
  message    String
  attachment String?
  isRead     Boolean       @default(false)
  status     MessageStatus @default(SENT)
  readAt     DateTime?
  createdAt  DateTime      @default(now())

  sender   User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  parent   Parent?  @relation(fields: [parentId], references: [id])
  teacher  Teacher? @relation(fields: [teacherId], references: [id])
  student  Student? @relation(fields: [studentId], references: [id])
  replyTo  Message? @relation("MessageReplies", fields: [replyToId], references: [id])
  replies  Message[] @relation("MessageReplies")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

