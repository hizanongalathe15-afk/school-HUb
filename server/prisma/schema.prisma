// ================================
// Device & Session Management
// ================================

enum DeviceSessionStatus {
  ACTIVE
  IDLE
  EXPIRED
}

model DeviceSession {
  id                String               @id @default(cuid())
  userId            String
  authSessionId     String?             // links to existing Session model token row if available
  fingerprint       String              // stable device fingerprint/hash
  ipAddress         String?
  ipMasked          String?
  userAgent         String?
  deviceType        String?
  browser           String?
  browserVersion    String?
  os                String?
  osVersion         String?
  screenResolution  String?
  timezone          String?
  latitude          Float?
  longitude         Float?
  city              String?
  country           String?
  countryCode       String?

  // lifecycle
  status            DeviceSessionStatus @default(ACTIVE)
  firstSeenAt      DateTime            @default(now())
  lastSeenAt       DateTime            @default(now())
  lastActivityAt   DateTime            @default(now())
  expiresAt        DateTime?
  revokedAt        DateTime?
  blockedAt        DateTime?

  // counters
  sessionStartAt    DateTime           @default(now())
  pagesViewed       Int                @default(0)
  actionsPerformed  Int                @default(0)

  // security/audit
  failedLoginAttempts Int             @default(0)

  // relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fingerprint])
  @@index([status])
  @@index([lastSeenAt])
}

model BlockedDevice {
  id             String   @id @default(cuid())
  fingerprint    String?  // stable fingerprint if client provides
  ipMasked       String?
  userAgentHash  String?
  reason         String
  blockedAt      DateTime @default(now())
  unblockedAt    DateTime?
  blockedBy      String?

  isActive       Boolean  @default(true)

  @@index([fingerprint])
  @@index([ipMasked])
  @@index([isActive])
}

// ================================
