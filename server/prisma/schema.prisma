// ================================

enum FeeTerm {
  TERM_1
  TERM_2
  TERM_3
  ANNUALLY
}

enum FeeFrequency {
  ONCE
  MONTHLY
  TERMLY
  ANNUALLY
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum ScholarshipStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

enum BudgetStatus {
  DRAFT
  APPROVED
  ACTIVE
  CLOSED
}

enum AssetStatus {
  ACTIVE
  DEPRECIATED
  DISPOSED
  UNDER_MAINTENANCE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

