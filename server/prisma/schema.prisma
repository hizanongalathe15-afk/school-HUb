  year            Int
  dueDate         DateTime
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  student        Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure   FeeStructure   @relation(fields: [feeStructureId], references: [id])
  component      FeeComponent?  @relation(fields: [componentId], references: [id])
  discounts      FeeDiscount[]
  scholarships   FeeScholarship[]
  paymentPlan    PaymentPlan?
  invoices       Invoice[]

  @@unique([studentId, feeStructureId, term, year])
}

model FeeDiscount {
  id                String   @id @default(cuid())
  studentFeeId      String
  type              String   // PERCENTAGE, FIXED
  amount            Float
  percentage        Float?
  reason            String
  approvedBy        String
  approvedAt        DateTime @default(now())
  createdAt         DateTime @default(now())

  studentFee StudentFeeAssignment @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)
}

model FeeScholarship {
  id                String            @id @default(cuid())
  studentFeeId      String
  scholarshipId     String
  amount            Float
  percentage        Float?
  academicYear      Int
  term              Int?
  status            ScholarshipStatus @default(ACTIVE)
  awardedBy         String
  awardedAt         DateTime          @default(now())
  createdAt         DateTime          @default(now())

  studentFee StudentFeeAssignment @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)
  scholarship ScholarshipProgram @relation(fields: [scholarshipId], references: [id])
}

model ScholarshipProgram {
  id                String   @id @default(cuid())
  name              String
  description       String?
  type              String   // ACADEMIC, NEEDY, SPORTS, SPECIAL_TALENT
  criteria          Json?    // {grade: "A", incomeLevel: "low", etc.}
  amount            Float?
  percentage        Float?
  duration          String   // TERM, YEAR, FULL_COURSE
  maxRecipients     Int?
  currentRecipients Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  awards            FeeScholarship[]
}

model PaymentPlan {
  id                String   @id @default(cuid())
  studentFeeId      String   @unique
  totalAmount       Float
  installmentCount  Int
  installmentAmount Float
  frequency         String   // WEEKLY, MONTHLY
  startDate         DateTime
  endDate           DateTime
  status            String   @default("ACTIVE") // ACTIVE, COMPLETED, DEFAULTED
  complianceRate    Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  studentFee StudentFeeAssignment @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)
  installments PaymentInstallment[]
}

model PaymentInstallment {
  id              String   @id @default(cuid())
  paymentPlanId   String
  installmentNumber Int
  dueDate         DateTime
  amount          Float
  paidAmount      Float    @default(0)
  status          String   @default("PENDING") // PENDING, PAID, OVERDUE
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  paymentPlan PaymentPlan @relation(fields: [paymentPlanId], references: [id], onDelete: Cascade)
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  studentFeeId    String
  studentId       String
  totalAmount     Float
  paidAmount      Float         @default(0)
  balanceAmount   Float
  dueDate         DateTime
  status          InvoiceStatus @default(DRAFT)
  notes           String?
  sentAt          DateTime?
  sentVia         String?       // EMAIL, SMS, WHATSAPP
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  studentFee StudentFeeAssignment @relation(fields: [studentFeeId], references: [id], onDelete: Cascade)
  items      InvoiceItem[]
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int      @default(1)
  unitPrice   Float
  amount      Float
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model ArrearsRecord {
  id              String   @id @default(cuid())
  studentId       String
  studentFeeId    String
  amount          Float
  daysOverdue     Int
  agingCategory   String   // 30, 60, 90+
  lastReminderAt  DateTime?
  reminderCount   Int      @default(0)
  escalationLevel Int      @default(0) // 0: none, 1: reminder, 2: principal, 3: admission hold
  isChronicDefaulter Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, studentFeeId])
}

model PettyCash {
  id              String   @id @default(cuid())
  custodianId     String
  floatAmount     Float
  currentBalance  Float
  limit           Float
  location        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    PettyCashTransaction[]
  replenishments  PettyCashReplenishment[]
}

model PettyCashTransaction {
  id              String   @id @default(cuid())
  pettyCashId     String
  type            String   // DEPOSIT, WITHDRAWAL
  amount          Float
  description     String
  category        String?
  receiptUrl      String?
  approvedBy      String?
  createdAt       DateTime @default(now())

  pettyCash PettyCash @relation(fields: [pettyCashId], references: [id], onDelete: Cascade)
}

model PettyCashReplenishment {
  id              String   @id @default(cuid())
  pettyCashId     String
  amount          Float
  requestedBy     String
  requestedAt     DateTime @default(now())
  approvedBy      String?
  approvedAt      DateTime?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())

  pettyCash PettyCash @relation(fields: [pettyCashId], references: [id], onDelete: Cascade)
}

model Payroll {
  id              String   @id @default(cuid())
  name            String
  month           Int
  year            Int
  processingDate  DateTime
  totalAmount     Float
  status          String   @default("DRAFT") // DRAFT, PROCESSED, PAID
  processedBy     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  entries         PayrollEntry[]
}

model PayrollEntry {
  id              String   @id @default(cuid())
  payrollId       String
  employeeId      String
  employeeType    String   // TEACHER, STAFF
  basicSalary     Float
  allowances      Json     // {housing: 5000, transport: 3000, ...}
  deductions      Json     // {PAYE: 2000, NHIF: 500, NSSF: 200, ...}
  bonuses         Float    @default(0)
  overtimePay     Float    @default(0)
  advances        Float    @default(0)
  netPay          Float
  payslipUrl      String?
  createdAt       DateTime @default(now())

  payroll Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)
}

model SalaryAdvance {
  id              String   @id @default(cuid())
  employeeId      String
  employeeType    String
  amount          Float
  reason          String
  repaymentAmount Float
  repaymentDeductions Int @default(0)
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED, REPAID
  approvedBy      String?
  approvedAt      DateTime?
  requestedAt     DateTime @default(now())
  repaidAt        DateTime?

  @@index([employeeId])
}

model Budget {
  id              String      @id @default(cuid())
  name            String
  academicYear    Int
  totalAmount     Float
  status          BudgetStatus @default(DRAFT)
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  allocations     BudgetAllocation[]
  actuals         BudgetActual[]
}

model BudgetAllocation {
  id              String   @id @default(cuid())
  budgetId        String
  department      String
  category        String
  allocatedAmount Float
  createdAt       DateTime @default(now())

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  actuals BudgetActual[]
}

model BudgetActual {
  id              String   @id @default(cuid())
  budgetId        String
  allocationId    String
  actualAmount    Float
  variance        Float
  variancePercent Float
  period          String   // MONTH_1, MONTH_2, etc.
  recordedAt      DateTime @default(now())

  budget     Budget           @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  allocation BudgetAllocation @relation(fields: [allocationId], references: [id])
}

model BankAccount {
  id              String   @id @default(cuid())
  bankName        String
  accountName     String
  accountNumber   String
  accountType     String   // CURRENT, SAVINGS
  currency        String   @default("KES")
  balance         Float
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    BankTransaction[]
  reconciliations BankReconciliation[]
}

model BankTransaction {
  id              String   @id @default(cuid())
  bankAccountId   String
  transactionId   String   @unique
  date            DateTime
  description     String
  amount          Float
  type            String   // CREDIT, DEBIT
  reference       String?
  isMatched       Boolean  @default(false)
  matchedTo       String?  // paymentId, expenseId
  createdAt       DateTime @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
}

model BankReconciliation {
  id              String   @id @default(cuid())
  bankAccountId   String
  period          String
  openingBalance  Float
  closingBalance  Float
  statementBalance Float
  variance        Float
  reconciledBy    String
  reconciledAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
}

model FixedAsset {
  id              String      @id @default(cuid())
  name            String
  category        String
  description     String?
  purchasePrice   Float
  currentValue    Float
  purchaseDate    DateTime
  location        String?
  assignedTo      String?
  depreciationMethod String @default("STRAIGHT_LINE")
  depreciationRate Float
  accumulatedDepreciation Float @default(0)
  status          AssetStatus @default(ACTIVE)
  disposalDate     DateTime?
  disposalReason   String?
  disposalAmount   Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  maintenanceRecords AssetMaintenance[]
}

model AssetMaintenance {
  id              String   @id @default(cuid())
  assetId         String
  date            DateTime
  description     String
  cost            Float
  performedBy     String?
  createdAt       DateTime @default(now())

  asset FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model ProjectFinancing {
  id              String      @id @default(cuid())
  name            String
  description     String?
  budgetAmount    Float
  actualAmount    Float
  startDate       DateTime
  endDate         DateTime?
  status          ProjectStatus @default(PLANNING)
  location        String?
  contractor      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  expenses        ProjectExpense[]
  milestones      ProjectMilestone[]
}

model ProjectExpense {
  id              String   @id @default(cuid())
  projectId       String
  description     String
  amount          Float
  date            DateTime
  category        String?
  invoiceUrl      String?
  createdAt       DateTime @default(now())

  project ProjectFinancing @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectMilestone {
  id              String   @id @default(cuid())
  projectId       String
  name            String
  description     String?
  targetDate      DateTime
  completedDate   DateTime?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())

  project ProjectFinancing @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BursarApplication {
  id              String   @id @default(cuid())
  scholarshipId   String?
  studentId       String
  parentId        String?
  type            String   // BURSARY, SCHOLARSHIP
  amountRequested Float
  reason          String
  documents       String[]
  status          String   @default("PENDING")
  reviewedBy      String?
  reviewedAt      DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model TaxRecord {
  id              String   @id @default(cuid())
  employeeId      String
  employeeType    String
  taxType         String   // PAYE, NHIF, NSSF, HOUSING_LEVY
  month           Int
  year            Int
  amount          Float
  paidAmount      Float    @default(0)
  balanceAmount   Float
  dueDate         DateTime
  paidAt          DateTime?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([employeeId, taxType, month, year])
}

model FinancialReport {
  id              String   @id @default(cuid())
  name            String
  type            String   // DAILY_COLLECTION, MONTHLY_INCOME, BALANCE_SHEET, etc.
  period          String
  data            Json
  generatedBy     String
  generatedAt     DateTime @default(now())
  fileUrl         String?

  @@index([type, period])
}

model BursarSetting {
  id                      String   @id @default(cuid())
  key                     String   @unique
  value                   Json
  description             String?
  updatedBy               String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
